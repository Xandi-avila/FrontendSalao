@using SalaoAdmin.Utilitarios

<MudGrid Spacing="2" Class="mb-4">
    <MudItem xs="6" sm="4" md="2">
        <MudPaper Class="pa-3 venda-card-op" Outlined="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Vendas hoje</MudText>
            <MudText Typo="Typo.h5">@Indicadores.QuantidadeVendasHoje</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="4" md="2">
        <MudPaper Class="pa-3 venda-card-op" Outlined="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Produtos hoje</MudText>
            <MudText Typo="Typo.h5">@Indicadores.QuantidadeProdutosHoje</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="4" md="2">
        <MudPaper Class="pa-3 venda-card-op" Outlined="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Serviços hoje</MudText>
            <MudText Typo="Typo.h5">@Indicadores.QuantidadeServicosHoje</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="4" md="2">
        <MudPaper Class="pa-3 venda-card-op" Outlined="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Valor hoje</MudText>
            <MudText Typo="Typo.h5" Color="Color.Success">@FormatacaoCampos.Moeda(Indicadores.ValorVendidoHoje)</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    public sealed class IndicadoresVenda
    {
        public int QuantidadeVendasHoje { get; init; }
        public int QuantidadeProdutosHoje { get; init; }
        public int QuantidadeServicosHoje { get; init; }
        public decimal ValorVendidoHoje { get; init; }
    }

    [Parameter] public IndicadoresVenda Indicadores { get; set; } = new();
}
