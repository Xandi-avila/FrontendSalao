<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Nome</MudText>
    </TitleContent>
    <DialogContent>
        <div class="d-flex justify-center pa-4">
            <MudImage Src="@UrlImagem"
                      Alt="@Nome"
                      ObjectFit="ObjectFit.Contain"
                      Style="max-width: min(90vw, 560px); max-height: min(70vh, 560px);" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Fechar">Fechar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Nome { get; set; } = string.Empty;
    [Parameter] public string UrlImagem { get; set; } = string.Empty;

    private void Fechar() => MudDialog.Close();
}
