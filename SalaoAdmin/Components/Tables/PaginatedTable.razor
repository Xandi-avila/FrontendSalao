<MudTablePager page="@(State.Page - 1)"
               pageSize="@State.PageSize"
               totalItems="@State.TotalItems"
               pageSizeOptions="@(new int[] { 5, 10, 25, 50 })"
               pageChanged="AoMudarPagina"
               pageSizeChanged="AoMudarTamanho"
               infoFormat="{first_item}-{last_item} de {all_items}"
               rowsPerPageString="Itens por página:" />

@code {
    [Parameter, EditorRequired] public PaginationState State { get; set; } = new();
    [Parameter] public EventCallback Atualizado { get; set; }

    private async Task AoMudarPagina(int indice)
    {
        State.Page = indice + 1;
        await Atualizado.InvokeAsync();
    }

    private async Task AoMudarTamanho(int tamanho)
    {
        State.PageSize = tamanho;
        State.Page = 1;
        await Atualizado.InvokeAsync();
    }
}
