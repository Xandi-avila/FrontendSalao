@using SalaoAdmin.Dtos.Categorias
@using SalaoAdmin.Dtos.Servicos
@using SalaoAdmin.Enums

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Modelo.Nome"
                      Label="Nome do serviço"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Required="true"
                      Error="@TemErro(nameof(Modelo.Nome))"
                      ErrorText="@MsgErro(nameof(Modelo.Nome))" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudNumericField @bind-Value="Modelo.DuracaoMinutos"
                         Label="Duração (minutos)"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="1"
                         Required="true"
                         Error="@TemErro(nameof(Modelo.DuracaoMinutos))"
                         ErrorText="@MsgErro(nameof(Modelo.DuracaoMinutos))" />
    </MudItem>
    <MudItem xs="12" md="6">
        <CampoMoeda @bind-ValorNumerico="Modelo.PrecoMinimo"
                    Rotulo="Preço mínimo"
                    Obrigatorio="true"
                    ComErro="@TemErro(nameof(Modelo.PrecoMinimo))"
                    TextoErro="@MsgErro(nameof(Modelo.PrecoMinimo))" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="Guid?"
                   Label="Categoria"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Required="true"
                   Value="CategoriaSelecionada"
                   ValueChanged="AoAlterarCategoria"
                   ToStringFunc="NomeCategoria"
                   Error="@TemErro(nameof(Modelo.CategoriaId))"
                   ErrorText="@MsgErro(nameof(Modelo.CategoriaId))">
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">Selecione a categoria</MudSelectItem>
            @foreach (var cat in Categorias)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)cat.Id)">@cat.Nome</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="4" Class="d-flex align-center">
        <MudSwitch @bind-Value="_ativo" Label="Serviço ativo" Color="Color.Primary" />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public ServicoCadastroDto Modelo { get; set; } = new();
    [Parameter] public IReadOnlyList<CategoriaDto> Categorias { get; set; } = [];
    [Parameter] public Dictionary<string, string> Erros { get; set; } = new();

    private bool _ativo = true;

    protected override void OnParametersSet() =>
        _ativo = Modelo.Status == StatusRegistro.Ativo;

    protected override void OnAfterRender(bool firstRender) =>
        Modelo.Status = _ativo ? StatusRegistro.Ativo : StatusRegistro.Inativo;

    private bool TemErro(string campo) => Erros.ContainsKey(campo);
    private string? MsgErro(string campo) => Erros.TryGetValue(campo, out var msg) ? msg : null;

    private Guid? CategoriaSelecionada =>
        Modelo.CategoriaId == Guid.Empty ? null : Modelo.CategoriaId;

    private void AoAlterarCategoria(Guid? id) =>
        Modelo.CategoriaId = id ?? Guid.Empty;

    private string NomeCategoria(Guid? id) =>
        id is null || id == Guid.Empty
            ? "Selecione a categoria"
            : Categorias.FirstOrDefault(c => c.Id == id)?.Nome ?? "Categoria não encontrada";
}
