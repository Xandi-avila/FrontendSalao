@using SalaoAdmin.Dtos.Funcionarios
@using SalaoAdmin.Enums

<MudGrid Spacing="3">
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="Modelo.NomeCompleto"
                      Label="Nome completo"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Required="true"
                      Error="@TemErro(nameof(Modelo.NomeCompleto))"
                      ErrorText="@MsgErro(nameof(Modelo.NomeCompleto))" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudSelect @bind-Value="Modelo.NivelPermissao"
                   Label="Função de acesso"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Required="true">
            @foreach (NivelPermissao nivel in Enum.GetValues<NivelPermissao>())
            {
                <MudSelectItem Value="@nivel">@nivel.Descricao()</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Modelo.Email"
                      Label="E-mail"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      InputType="InputType.Email"
                      Required="true"
                      Error="@TemErro(nameof(Modelo.Email))"
                      ErrorText="@MsgErro(nameof(Modelo.Email))" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Modelo.Senha"
                      Label="@(Edicao ? "Nova senha (opcional)" : "Senha")"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      InputType="InputType.Password"
                      Required="@(!Edicao)"
                      Error="@TemErro(nameof(Modelo.Senha))"
                      ErrorText="@MsgErro(nameof(Modelo.Senha))" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Modelo.Telefone"
                      Label="Telefone"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Required="true"
                      Error="@TemErro(nameof(Modelo.Telefone))"
                      ErrorText="@MsgErro(nameof(Modelo.Telefone))" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Modelo.Celular"
                      Label="Celular"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      InputType="InputType.Telephone" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Modelo.CPF"
                      Label="CPF"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      MaxLength="14" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField T="string"
                      Value="ProfissoesTexto"
                      ValueChanged="EventCallback.Factory.Create<string>(this, AtualizarProfissoes)"
                      Label="Profissões (separe por vírgula)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="2"
                      Error="@TemErro(nameof(Modelo.Profissoes))"
                      ErrorText="@MsgErro(nameof(Modelo.Profissoes))" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Modelo.DataAdmissao"
                       Label="Data de admissão"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       DateFormat="dd/MM/yyyy"
                       Editable="true"
                       Clearable="true" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudDatePicker @bind-Date="Modelo.DataNascimento"
                       Label="Data de nascimento"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       DateFormat="dd/MM/yyyy"
                       Editable="true"
                       Clearable="true" />
    </MudItem>
    <MudItem xs="12">
        <MudTextField @bind-Value="Modelo.Endereco"
                      Label="Endereço"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="2"
                      Required="true"
                      Error="@TemErro(nameof(Modelo.Endereco))"
                      ErrorText="@MsgErro(nameof(Modelo.Endereco))" />
    </MudItem>
    <MudItem xs="12">
        <MudSwitch @bind-Value="_ativo" Label="Funcionário ativo" Color="Color.Primary" />
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public FuncionarioCadastroDto Modelo { get; set; } = new();
    [Parameter] public Dictionary<string, string> Erros { get; set; } = new();
    [Parameter] public bool Edicao { get; set; }

    private bool _ativo = true;
    private string ProfissoesTexto { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        _ativo = Modelo.Status == StatusRegistro.Ativo;
        ProfissoesTexto = string.Join(", ", Modelo.Profissoes ?? new List<string>());
    }

    protected override void OnAfterRender(bool firstRender) =>
        Modelo.Status = _ativo ? StatusRegistro.Ativo : StatusRegistro.Inativo;

    private void AtualizarProfissoes(string valor)
    {
        ProfissoesTexto = valor;
        Modelo.Profissoes = valor?
            .Split(',')
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList() ?? new List<string>();
    }

    private bool TemErro(string campo) => Erros.ContainsKey(campo);
    private string? MsgErro(string campo) => Erros.TryGetValue(campo, out var msg) ? msg : null;
}

