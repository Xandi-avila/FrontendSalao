@page "/vendas/historico"
@layout AdminLayout
@using SalaoAdmin.Dtos.Funcionarios
@using SalaoAdmin.Enums
@inject IVendaServico VendaServico
@inject IClienteServico ClienteServico
@inject IFuncionarioServico FuncionarioServico
@inject TokenStorageService TokenStorage
@inject IServicoNotificacao Notificacoes
@inject NavigationManager Navegacao
@implements IDisposable

<CabecalhoPagina Titulo="Histórico de vendas"
                 Subtitulo="Historico de vendas de pedidos e produtos.">
    <Acoes>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PointOfSale"
                   Href="/vendas">Nova venda</MudButton>
    </Acoes>
</CabecalhoPagina>

<MudPaper Class="pa-4 mb-4" Outlined="true">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="Data inicial" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Date="_filtroInicio" DateChanged="v => _filtroInicio = v" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="Data final" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Date="_filtroFim" DateChanged="v => _filtroFim = v" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudAutocomplete T="ClienteDto" Label="Cliente" Variant="Variant.Outlined" Margin="Margin.Dense"
                             SearchFunc="BuscarClientes" ToStringFunc="@(c => c?.NomeCompleto ?? "")"
                             Value="_clienteFiltro" ValueChanged="v => _clienteFiltro = v"
                             CompareWith="CompararClientes"
                             Clearable="true" ResetValueOnEmptyText="true" />
        </MudItem>
        @if (_podeVerTodosFuncionarios)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudAutocomplete T="FuncionarioDto" Label="Funcionário" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 SearchFunc="BuscarFuncionarios" ToStringFunc="@(f => f?.NomeCompleto ?? "")"
                                 Value="_funcionarioFiltro" ValueChanged="v => _funcionarioFiltro = v"
                                 CompareWith="CompararFuncionarios"
                                 Clearable="true" ResetValueOnEmptyText="true" />
            </MudItem>
        }
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string" Label="Tipo de item" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Value="_filtroTipo" ValueChanged="v => _filtroTipo = v" Clearable="true">
                <MudSelectItem T="string" Value="@((string?)null)">Todos</MudSelectItem>
                <MudSelectItem T="string" Value="@TipoItemVenda.Produto">Produtos</MudSelectItem>
                <MudSelectItem T="string" Value="@TipoItemVenda.Servico">Serviços</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_busca" Placeholder="Buscar por venda"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="6" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Carregar" Class="mr-2">Filtrar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros">Limpar</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<div style="position: relative; min-height: 200px;">
    <OverlayCarregando Visivel="_carregando" />

    @if (!_carregando && _lista.Count == 0)
    {
        <EstadoVazio Titulo="Nenhuma venda" Descricao="Registre vendas no PDV ou altere os filtros."
                     Icone="@Icons.Material.Filled.ReceiptLong">
            <Acao>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/vendas">Ir ao PDV</MudButton>
            </Acao>
        </EstadoVazio>
    }
    else if (!_carregando)
    {
        <MudTable Items="_linhasHistorico" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1"
                  OnRowClick="AbrirDetalhe" T="LinhaHistoricoVenda" RowClass="cursor-pointer">
            <HeaderContent>
                <MudTh>Venda</MudTh>
                @if (_podeVerTodosFuncionarios)
                {
                    <MudTh>Funcionário</MudTh>
                }
                <MudTh>Cliente</MudTh>
                <MudTh>Data</MudTh>
                <MudTh>Itens</MudTh>
                <MudTh>Total</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Venda">
                    <MudText Typo="Typo.body2"><strong>@VendaExibicaoHelper.NumeroAmigavel(context.Venda)</strong></MudText>
                </MudTd>
                @if (_podeVerTodosFuncionarios)
                {
                    <MudTd DataLabel="Funcionário">@NomeFuncionario(context.Venda.FuncionarioId)</MudTd>
                }
                <MudTd DataLabel="Cliente">@NomeCliente(context.Venda.ClienteId)</MudTd>
                <MudTd DataLabel="Data">@context.Venda.DataHora.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Itens">@VendaCalculoHelper.TextoResumoItens(context.Venda)</MudTd>
                <MudTd DataLabel="Total">@FormatacaoCampos.Moeda(context.Venda.Total)</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@VendaExibicaoHelper.TextoStatus()</MudChip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager page="@(_pagina - 1)" pageSize="@_itensPorPagina" totalItems="@_total"
                               pageChanged="p => { _pagina = p + 1; _ = Carregar(); }"
                               pageSizeChanged="s => { _itensPorPagina = s; _pagina = 1; _ = Carregar(); }" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private bool _carregando = true;
    private int _versaoCarregar;
    private CancellationTokenSource? _ctsCarregar;
    private List<VendaDto> _lista = [];
    private List<LinhaHistoricoVenda> _linhasHistorico = [];
    private Dictionary<Guid, int> _numerosVendas = new();
    private Task? _mapaNumerosTask;
    private readonly Dictionary<Guid, string> _nomesClientes = new();
    private readonly Dictionary<Guid, string> _nomesFuncionarios = new();
    private List<ClienteDto> _clientes = [];
    private List<FuncionarioDto> _funcionarios = [];
    private bool _podeVerTodosFuncionarios;
    private Guid _funcionarioLogadoId;

    private sealed class LinhaHistoricoVenda
    {
        public required VendaDto Venda { get; init; }
    }

    private int _pagina = 1;
    private int _itensPorPagina = 15;
    private int _total;
    private string _busca = string.Empty;
    private DateTime? _filtroInicio;
    private DateTime? _filtroFim;
    private ClienteDto? _clienteFiltro;
    private FuncionarioDto? _funcionarioFiltro;
    private string? _filtroTipo;

    protected override async Task OnInitializedAsync()
    {
        var usuario = await TokenStorage.ObterUsuarioAsync();
        if (usuario is not null)
        {
            _funcionarioLogadoId = usuario.Id;
            _podeVerTodosFuncionarios = (int)usuario.NivelPermissao >= (int)NivelPermissao.Gerente;
        }

        DefinirPeriodoPadrao();
        await CarregarClientesAsync();
        if (_podeVerTodosFuncionarios)
            await CarregarFuncionariosAsync();
        IniciarMapaNumerosEmBackground();
        await Carregar();
    }

    public void Dispose()
    {
        _ctsCarregar?.Cancel();
        _ctsCarregar?.Dispose();
    }

    private void DefinirPeriodoPadrao()
    {
        _filtroInicio = DateTime.Today.AddDays(-7);
        _filtroFim = DateTime.Today;
    }

    private async Task CarregarClientesAsync()
    {
        var todos = new List<ClienteDto>();
        var pagina = 1;

        while (true)
        {
            var resposta = await ClienteServico.ListarAsync(new FiltroPaginacao
            {
                Pagina = pagina,
                ItensPorPagina = 100
            });

            if (!resposta.Sucesso || resposta.Dados is null || resposta.Dados.Itens.Count == 0)
                break;

            todos.AddRange(resposta.Dados.Itens);
            if (todos.Count >= resposta.Dados.Total)
                break;

            pagina++;
        }

        _clientes = todos.OrderBy(c => c.NomeCompleto).ToList();
    }

    private async Task CarregarFuncionariosAsync()
    {
        var todos = new List<FuncionarioDto>();
        var pagina = 1;

        while (true)
        {
            var resposta = await FuncionarioServico.ListarAsync(new FiltroPaginacao
            {
                Pagina = pagina,
                ItensPorPagina = 100
            });

            if (!resposta.Sucesso || resposta.Dados is null || resposta.Dados.Itens.Count == 0)
                break;

            todos.AddRange(resposta.Dados.Itens);
            if (todos.Count >= resposta.Dados.Total)
                break;

            pagina++;
        }

        _funcionarios = todos.OrderBy(f => f.NomeCompleto).ToList();
    }

    private async Task Carregar()
    {
        var versao = Interlocked.Increment(ref _versaoCarregar);

        _ctsCarregar?.Cancel();
        _ctsCarregar?.Dispose();
        _ctsCarregar = new CancellationTokenSource();
        var cancelamento = _ctsCarregar.Token;

        _carregando = true;

        try
        {
            if (_funcionarioFiltro is not null && _podeVerTodosFuncionarios && !VendaNumeroHelper.TryParseNumeroBusca(_busca, out _))
                await CarregarVendasFuncionarioAsync(versao, cancelamento);
            else if (_clienteFiltro is not null && !VendaNumeroHelper.TryParseNumeroBusca(_busca, out _))
                await CarregarVendasClienteAsync(versao, cancelamento);
            else
                await CarregarVendasServicoAsync(versao, cancelamento);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (versao == _versaoCarregar)
                _carregando = false;
        }
    }

    private Guid? FuncionarioIdConsulta =>
        _podeVerTodosFuncionarios ? _funcionarioFiltro?.Id : _funcionarioLogadoId;

    private IEnumerable<VendaDto> FiltrarPorPermissao(IEnumerable<VendaDto> vendas) =>
        _podeVerTodosFuncionarios
            ? vendas
            : vendas.Where(v => v.FuncionarioId == _funcionarioLogadoId);

    private async Task CarregarVendasClienteAsync(int versao, CancellationToken cancelamento)
    {
        var resposta = await VendaServico.ListarAsync(new FiltroVenda
        {
            ClienteId = _clienteFiltro!.Id,
            FuncionarioId = FuncionarioIdConsulta,
            Pagina = 1,
            ItensPorPagina = 100
        }, cancelamento);

        if (versao != _versaoCarregar || cancelamento.IsCancellationRequested)
            return;

        if (!resposta.Sucesso || resposta.Dados is null)
        {
            Notificacoes.Erro(resposta.Mensagem ?? "Erro ao carregar vendas.");
            _lista = [];
            _linhasHistorico = [];
            _total = 0;
            return;
        }

        var filtradas = FiltrarPorPermissao(resposta.Dados.Itens)
            .Where(v => VendaCalculoHelper.VendaNoPeriodo(v, _filtroInicio, _filtroFim))
            .Where(v => string.IsNullOrWhiteSpace(_filtroTipo) || VendaCalculoHelper.VendaContemTipo(v, _filtroTipo!))
            .OrderByDescending(v => v.DataHora)
            .ToList();

        _total = filtradas.Count;
        _lista = filtradas
            .Skip((_pagina - 1) * _itensPorPagina)
            .Take(_itensPorPagina)
            .ToList();
        AplicarNumerosGlobais(_lista);
        _linhasHistorico = _lista.Select(v => new LinhaHistoricoVenda { Venda = v }).ToList();
        _nomesClientes[_clienteFiltro.Id] = _clienteFiltro.NomeCompleto;

        if (_numerosVendas.Count == 0)
            IniciarMapaNumerosEmBackground();
    }

    private async Task CarregarVendasFuncionarioAsync(int versao, CancellationToken cancelamento)
    {
        var resposta = await VendaServico.ListarAsync(new FiltroVenda
        {
            FuncionarioId = _funcionarioFiltro!.Id,
            ClienteId = _clienteFiltro?.Id,
            Pagina = 1,
            ItensPorPagina = 100
        }, cancelamento);

        if (versao != _versaoCarregar || cancelamento.IsCancellationRequested)
            return;

        if (!resposta.Sucesso || resposta.Dados is null)
        {
            Notificacoes.Erro(resposta.Mensagem ?? "Erro ao carregar vendas.");
            _lista = [];
            _linhasHistorico = [];
            _total = 0;
            return;
        }

        var filtradas = FiltrarPorPermissao(resposta.Dados.Itens)
            .Where(v => VendaCalculoHelper.VendaNoPeriodo(v, _filtroInicio, _filtroFim))
            .Where(v => string.IsNullOrWhiteSpace(_filtroTipo) || VendaCalculoHelper.VendaContemTipo(v, _filtroTipo!))
            .Where(v => _clienteFiltro is null || v.ClienteId == _clienteFiltro.Id)
            .OrderByDescending(v => v.DataHora)
            .ToList();

        _total = filtradas.Count;
        _lista = filtradas
            .Skip((_pagina - 1) * _itensPorPagina)
            .Take(_itensPorPagina)
            .ToList();
        AplicarNumerosGlobais(_lista);
        _linhasHistorico = _lista.Select(v => new LinhaHistoricoVenda { Venda = v }).ToList();
        _nomesFuncionarios[_funcionarioFiltro.Id] = _funcionarioFiltro.NomeCompleto;

        if (_clienteFiltro is not null)
            _nomesClientes[_clienteFiltro.Id] = _clienteFiltro.NomeCompleto;

        if (_numerosVendas.Count == 0)
            IniciarMapaNumerosEmBackground();
    }

    private async Task CarregarVendasServicoAsync(int versao, CancellationToken cancelamento)
    {
        var resposta = await VendaServico.ListarAsync(new FiltroVenda
        {
            Pagina = _pagina,
            ItensPorPagina = _itensPorPagina,
            ClienteId = _clienteFiltro?.Id,
            FuncionarioId = FuncionarioIdConsulta,
            Inicio = _filtroInicio,
            Fim = _filtroFim,
            TipoItem = _filtroTipo,
            Busca = _busca
        }, cancelamento);

        if (versao != _versaoCarregar || cancelamento.IsCancellationRequested)
            return;

        if (!resposta.Sucesso || resposta.Dados is null)
        {
            Notificacoes.Erro(resposta.Mensagem ?? "Erro ao carregar vendas.");
            _lista = [];
            _linhasHistorico = [];
            _total = 0;
            return;
        }

        var filtradas = FiltrarPorPermissao(resposta.Dados.Itens).ToList();
        _lista = filtradas;
        _total = resposta.Dados.Total;
        AplicarNumerosGlobais(_lista);
        _linhasHistorico = _lista.Select(v => new LinhaHistoricoVenda { Venda = v }).ToList();

        if (_clienteFiltro is not null)
            _nomesClientes[_clienteFiltro.Id] = _clienteFiltro.NomeCompleto;
        else
            PreencherNomesClientesLocais(_lista);

        if (_funcionarioFiltro is not null)
            _nomesFuncionarios[_funcionarioFiltro.Id] = _funcionarioFiltro.NomeCompleto;
        else
            PreencherNomesFuncionariosLocais(_lista);
    }

    private void IniciarMapaNumerosEmBackground()
    {
        if (_mapaNumerosTask is not null)
            return;

        _mapaNumerosTask = CarregarMapaNumerosEmBackgroundAsync();
    }

    private async Task CarregarMapaNumerosEmBackgroundAsync()
    {
        try
        {
            _numerosVendas = await VendaNumeroHelper.MontarMapaGlobalAsync(VendaServico);
            if (_lista.Count == 0)
                return;

            AplicarNumerosGlobais(_lista);
            _linhasHistorico = _lista.Select(v => new LinhaHistoricoVenda { Venda = v }).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private void AplicarNumerosGlobais(IEnumerable<VendaDto> vendas)
    {
        if (_numerosVendas.Count == 0)
            return;

        foreach (var venda in vendas)
        {
            if (_numerosVendas.TryGetValue(venda.Id, out var numero))
                venda.Numero = numero;
        }
    }

    private void PreencherNomesClientesLocais(IEnumerable<VendaDto> vendas)
    {
        foreach (var id in vendas.Where(v => v.ClienteId.HasValue).Select(v => v.ClienteId!.Value).Distinct())
        {
            if (_nomesClientes.ContainsKey(id))
                continue;

            var local = _clientes.FirstOrDefault(c => c.Id == id);
            if (local is not null)
                _nomesClientes[id] = local.NomeCompleto;
        }
    }

    private void PreencherNomesFuncionariosLocais(IEnumerable<VendaDto> vendas)
    {
        foreach (var id in vendas.Select(v => v.FuncionarioId).Distinct())
        {
            if (_nomesFuncionarios.ContainsKey(id))
                continue;

            var local = _funcionarios.FirstOrDefault(f => f.Id == id);
            if (local is not null)
                _nomesFuncionarios[id] = local.NomeCompleto;
        }
    }

    private Task LimparFiltros()
    {
        _busca = string.Empty;
        DefinirPeriodoPadrao();
        _clienteFiltro = null;
        _funcionarioFiltro = null;
        _filtroTipo = null;
        _pagina = 1;
        return Carregar();
    }

    private Task<IEnumerable<ClienteDto>> BuscarClientes(string texto, CancellationToken _)
    {
        if (_clientes.Count == 0)
            return Task.FromResult(Enumerable.Empty<ClienteDto>());

        if (string.IsNullOrWhiteSpace(texto))
            return Task.FromResult(_clientes.Take(20).AsEnumerable());

        var busca = texto.Trim().ToLowerInvariant();
        return Task.FromResult(_clientes.Where(c =>
                c.NomeCompleto.ToLowerInvariant().Contains(busca) ||
                c.WhatsApp.Contains(busca) ||
                c.Email?.ToLowerInvariant().Contains(busca) == true)
            .Take(20));
    }

    private static bool CompararClientes(ClienteDto? a, ClienteDto? b) =>
        a?.Id == b?.Id;

    private Task<IEnumerable<FuncionarioDto>> BuscarFuncionarios(string texto, CancellationToken _)
    {
        if (_funcionarios.Count == 0)
            return Task.FromResult(Enumerable.Empty<FuncionarioDto>());

        if (string.IsNullOrWhiteSpace(texto))
            return Task.FromResult(_funcionarios.Take(20).AsEnumerable());

        var busca = texto.Trim().ToLowerInvariant();
        return Task.FromResult(_funcionarios.Where(f =>
                f.NomeCompleto.ToLowerInvariant().Contains(busca) ||
                f.Email.ToLowerInvariant().Contains(busca) ||
                f.Telefone.Contains(busca))
            .Take(20));
    }

    private static bool CompararFuncionarios(FuncionarioDto? a, FuncionarioDto? b) =>
        a?.Id == b?.Id;

    private void AbrirDetalhe(TableRowClickEventArgs<LinhaHistoricoVenda> args)
    {
        if (args.Item is null) return;
        Navegacao.NavigateTo($"/vendas/{args.Item.Venda.Id}");
    }

    private string NomeCliente(Guid? id)
    {
        if (id is null)
            return "—";
        if (_clienteFiltro?.Id == id)
            return _clienteFiltro.NomeCompleto;
        if (_nomesClientes.TryGetValue(id.Value, out var nome))
            return nome;
        var local = _clientes.FirstOrDefault(c => c.Id == id);
        return local?.NomeCompleto ?? "Cliente";
    }

    private string NomeFuncionario(Guid id)
    {
        if (_funcionarioFiltro?.Id == id)
            return _funcionarioFiltro.NomeCompleto;
        if (_nomesFuncionarios.TryGetValue(id, out var nome))
            return nome;
        var local = _funcionarios.FirstOrDefault(f => f.Id == id);
        return local?.NomeCompleto ?? "Funcionário";
    }
}
