@page "/produtos"
@layout AdminLayout
@inject IProdutoServico ProdutoServico
@inject IServicoNotificacao Notificacoes
@inject IDialogService Dialogos
@inject NavigationManager Navegacao

<CabecalhoPagina Titulo="Produtos" Subtitulo="Produtos vendidos no salão">
    <Acoes>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navegacao.NavigateTo("/produtos/cadastro"))">
            Novo produto
        </MudButton>
    </Acoes>
</CabecalhoPagina>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudTextField @bind-Value="_busca"
                  Placeholder="Buscar produto..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  DebounceInterval="400"
                  OnDebounceIntervalElapsed="Carregar"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense" />
</MudPaper>

<div style="position: relative; min-height: 200px;">
    <OverlayCarregando Visivel="_carregando" />

    @if (!_carregando && _lista.Count == 0)
    {
        <EstadoVazio Titulo="Nenhum produto" Descricao="Cadastre um produto ou altere o filtro." Icone="@Icons.Material.Filled.Inventory2">
            <Acao>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@(() => Navegacao.NavigateTo("/produtos/cadastro"))">
                    Cadastrar
                </MudButton>
            </Acao>
        </EstadoVazio>
    }
    else if (!_carregando)
    {
        <MudTable Items="_lista" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
            <HeaderContent>
                <MudTh>Produto</MudTh>
                <MudTh>Valor</MudTh>
                <MudTh>Status</MudTh>
                <MudTh Style="width: 120px">Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Produto">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (!string.IsNullOrEmpty(context.CaminhoImagem))
                        {
                            <span @onclick:stopPropagation="true">
                                <MudAvatar Size="Size.Small" Class="cursor-pointer"
                                           @onclick="@(() => AbrirImagemProduto(context))">
                                    <MudImage Src="@context.CaminhoImagem" Alt="@context.Nome" />
                                </MudAvatar>
                            </span>
                        }
                        @context.Nome
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Valor">@FormatacaoCampos.Moeda(context.Valor)</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Status == StatusRegistro.Ativo ? Color.Success : Color.Default)">
                        @context.Status.Descricao()
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => Navegacao.NavigateTo($"/produtos/editar/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => ConfirmarExclusao(context))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager page="@(_pagina - 1)"
                               pageSize="@_itensPorPagina"
                               totalItems="@_total"
                               pageSizeOptions="@(new int[] { 5, 10, 25 })"
                               pageChanged="MudarPagina"
                               pageSizeChanged="MudarTamanhoPagina"
                               infoFormat="{first_item}-{last_item} de {all_items}" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<ProdutoDto> _lista = [];
    private bool _carregando = true;
    private string? _busca;
    private int _pagina = 1;
    private int _itensPorPagina = 10;
    private int _total;

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        _carregando = true;
        StateHasChanged();

        try
        {
            var resposta = await ProdutoServico.ListarAsync(new FiltroPaginacao
            {
                Pagina = _pagina,
                ItensPorPagina = _itensPorPagina,
                Busca = _busca
            });

            if (resposta.Sucesso && resposta.Dados is not null)
            {
                _lista = resposta.Dados.Itens.ToList();
                _total = resposta.Dados.Total;
            }
            else
                Notificacoes.Erro(resposta.Mensagem ?? "Não foi possível carregar a lista.");
        }
        catch (Exception ex)
        {
            Notificacoes.Erro(ex.Message);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task MudarPagina(int indice) { _pagina = indice + 1; await Carregar(); }
    private async Task MudarTamanhoPagina(int tamanho) { _itensPorPagina = tamanho; _pagina = 1; await Carregar(); }

    private async Task ConfirmarExclusao(ProdutoDto item)
    {
        var parametros = new DialogParameters<DialogoConfirmacao>
        {
            { x => x.Mensagem, $"Excluir \"{item.Nome}\"?" }
        };
        var dialogo = await Dialogos.ShowAsync<DialogoConfirmacao>("Confirmar", parametros);
        var retorno = await dialogo.Result;
        if (retorno is null || retorno.Canceled) return;

        var exclusao = await ProdutoServico.ExcluirAsync(item.Id);
        if (exclusao.Sucesso)
        {
            Notificacoes.Sucesso(exclusao.Mensagem ?? "Registro excluído.");
            await Carregar();
        }
        else
            Notificacoes.Erro(exclusao.Mensagem ?? "Não foi possível excluir.");
    }

    private async Task AbrirImagemProduto(ProdutoDto produto)
    {
        if (string.IsNullOrWhiteSpace(produto.CaminhoImagem)) return;

        var opcoes = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var parametros = new DialogParameters<DialogoImagemProduto>
        {
            { x => x.Nome, produto.Nome },
            { x => x.UrlImagem, produto.CaminhoImagem }
        };

        await Dialogos.ShowAsync<DialogoImagemProduto>(produto.Nome, parametros, opcoes);
    }
}
