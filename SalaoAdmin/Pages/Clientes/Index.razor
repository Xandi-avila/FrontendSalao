@page "/clientes"
@layout AdminLayout
@inject IClienteServico ClienteServico
@inject IServicoNotificacao Notificacoes
@inject IDialogService Dialogos
@inject NavigationManager Navegacao

<CabecalhoPagina Titulo="Clientes" Subtitulo="Cadastro de clientes do salão">
    <Acoes>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navegacao.NavigateTo("/clientes/cadastro"))">
            Novo cliente
        </MudButton>
    </Acoes>
</CabecalhoPagina>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudTextField @bind-Value="_busca"
                      Placeholder="Nome, Telefone, E-mail.."
                  DebounceInterval="400"
                  OnDebounceIntervalElapsed="Carregar"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense" />
</MudPaper>

<div style="position: relative; min-height: 200px;">
    <OverlayCarregando Visivel="_carregando" />

    @if (!_carregando && _lista.Count == 0)
    {
        <EstadoVazio Titulo="Nenhum cliente encontrado"
                     Descricao="Cadastre um cliente ou altere o filtro de busca."
                     Icone="@Icons.Material.Filled.People">
            <Acao>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@(() => Navegacao.NavigateTo("/clientes/cadastro"))">
                    Cadastrar cliente
                </MudButton>
            </Acao>
        </EstadoVazio>
    }
    else if (!_carregando)
    {
        <MudTable Items="_lista" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
            <HeaderContent>
                <MudTh>Nome</MudTh>
                <MudTh>WhatsApp</MudTh>
                <MudTh>E-mail</MudTh>
                <MudTh>Rede social</MudTh>
                <MudTh>Profissões</MudTh>
                <MudTh>Nascimento</MudTh>
                <MudTh>Endereço</MudTh>
                <MudTh Style="width: 120px">Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nome">@context.NomeCompleto</MudTd>
                <MudTd DataLabel="WhatsApp">@FormatacaoCampos.Telefone(context.WhatsApp)</MudTd>
                <MudTd DataLabel="E-mail">@(context.Email ?? "—")</MudTd>
                <MudTd DataLabel="Rede social">@(context.Instagram ?? "—")</MudTd>
                <MudTd DataLabel="Profissões">@ProfissoesHelper.Exibir(context.Profissao)</MudTd>
                <MudTd DataLabel="Nascimento">@(context.DataNascimento?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
                <MudTd DataLabel="Endereço">@context.Endereco</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => Navegacao.NavigateTo($"/clientes/editar/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => ConfirmarExclusao(context))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager page="@(_pagina - 1)"
                               pageSize="@_itensPorPagina"
                               totalItems="@_total"
                               pageSizeOptions="@(new int[] { 5, 10, 25 })"
                               pageChanged="MudarPagina"
                               pageSizeChanged="MudarTamanhoPagina"
                               infoFormat="{first_item}-{last_item} de {all_items}" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<ClienteDto> _lista = [];
    private bool _carregando = true;
    private string? _busca;
    private int _pagina = 1;
    private int _itensPorPagina = 10;
    private int _total;

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        _carregando = true;
        StateHasChanged();

        try
        {
            var resposta = await ClienteServico.ListarAsync(new FiltroPaginacao
            {
                Pagina = _pagina,
                ItensPorPagina = _itensPorPagina,
                Busca = _busca
            });

            if (resposta.Sucesso && resposta.Dados is not null)
            {
                _lista = resposta.Dados.Itens.ToList();
                _total = resposta.Dados.Total;
            }
            else
                Notificacoes.Erro(resposta.Mensagem ?? "Não foi possível carregar a lista.");
        }
        catch (Exception ex)
        {
            Notificacoes.Erro(ex.Message);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task MudarPagina(int indice) { _pagina = indice + 1; await Carregar(); }
    private async Task MudarTamanhoPagina(int tamanho) { _itensPorPagina = tamanho; _pagina = 1; await Carregar(); }

    private async Task ConfirmarExclusao(ClienteDto item)
    {
        var parametros = new DialogParameters<DialogoConfirmacao>
        {
            { x => x.Mensagem, $"Excluir \"{item.NomeCompleto}\"?" }
        };
        var dialogo = await Dialogos.ShowAsync<DialogoConfirmacao>("Confirmar", parametros);
        var retorno = await dialogo.Result;
        if (retorno is null || retorno.Canceled) return;

        var exclusao = await ClienteServico.ExcluirAsync(item.Id);
        if (exclusao.Sucesso)
        {
            Notificacoes.Sucesso(exclusao.Mensagem ?? "Registro excluído.");
            await Carregar();
        }
        else
            Notificacoes.Erro(exclusao.Mensagem ?? "Não foi possível excluir.");
    }
}
