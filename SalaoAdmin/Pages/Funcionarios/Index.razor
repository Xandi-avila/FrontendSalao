@page "/funcionarios"
@layout AdminLayout
@inject IFuncionarioServico FuncionarioServico
@inject IServicoNotificacao Notificacoes
@inject IDialogService Dialogos
@inject NavigationManager Navegacao

<CabecalhoPagina Titulo="Funcionários" Subtitulo="Equipe do salão">
    <Acoes>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navegacao.NavigateTo("/funcionarios/cadastro"))">
            Novo funcionário
        </MudButton>
    </Acoes>
</CabecalhoPagina>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudTextField @bind-Value="_busca"
                  Placeholder="Nome, e-mail ou cargo..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  DebounceInterval="400"
                  OnDebounceIntervalElapsed="Carregar"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense" />
</MudPaper>

<div style="position: relative; min-height: 200px;">
    <OverlayCarregando Visivel="_carregando" />

    @if (!_carregando && _lista.Count == 0)
    {
        <EstadoVazio Titulo="Nenhum funcionário" Descricao="Cadastre alguém da equipe ou mude o filtro." Icone="@Icons.Material.Filled.Badge">
            <Acao>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@(() => Navegacao.NavigateTo("/funcionarios/cadastro"))">
                    Cadastrar
                </MudButton>
            </Acao>
        </EstadoVazio>
    }
    else if (!_carregando)
    {
        <MudTable Items="_lista" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
            <HeaderContent>
                <MudTh>Nome</MudTh>
                <MudTh>E-mail</MudTh>
                <MudTh>Cargo</MudTh>
                <MudTh>Permissão</MudTh>
                <MudTh>Status</MudTh>
                <MudTh Style="width: 120px">Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nome">@context.NomeCompleto</MudTd>
                <MudTd DataLabel="E-mail">@context.Email</MudTd>
                <MudTd DataLabel="Cargo">@context.ProfissaoCargo</MudTd>
                <MudTd DataLabel="Permissão">@context.NivelPermissao.Descricao()</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Status == StatusRegistro.Ativo ? Color.Success : Color.Default)">
                        @context.Status.Descricao()
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => Navegacao.NavigateTo($"/funcionarios/editar/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => ConfirmarExclusao(context))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager page="@(_pagina - 1)"
                               pageSize="@_itensPorPagina"
                               totalItems="@_total"
                               pageSizeOptions="@(new int[] { 5, 10, 25 })"
                               pageChanged="MudarPagina"
                               pageSizeChanged="MudarTamanhoPagina"
                               infoFormat="{first_item}-{last_item} de {all_items}" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<FuncionarioDto> _lista = [];
    private bool _carregando = true;
    private string? _busca;
    private int _pagina = 1;
    private int _itensPorPagina = 10;
    private int _total;

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        _carregando = true;
        StateHasChanged();

        try
        {
            var resposta = await FuncionarioServico.ListarAsync(new FiltroPaginacao
            {
                Pagina = _pagina,
                ItensPorPagina = _itensPorPagina,
                Busca = _busca
            });

            if (resposta.Sucesso && resposta.Dados is not null)
            {
                _lista = resposta.Dados.Itens.ToList();
                _total = resposta.Dados.Total;
            }
            else
                Notificacoes.Erro(resposta.Mensagem ?? "Não foi possível carregar a lista.");
        }
        catch (Exception ex)
        {
            Notificacoes.Erro(ex.Message);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task MudarPagina(int indice) { _pagina = indice + 1; await Carregar(); }
    private async Task MudarTamanhoPagina(int tamanho) { _itensPorPagina = tamanho; _pagina = 1; await Carregar(); }

    private async Task ConfirmarExclusao(FuncionarioDto item)
    {
        var parametros = new DialogParameters<DialogoConfirmacao>
        {
            { x => x.Mensagem, $"Excluir \"{item.NomeCompleto}\"?" }
        };
        var dialogo = await Dialogos.ShowAsync<DialogoConfirmacao>("Confirmar", parametros);
        var retorno = await dialogo.Result;
        if (retorno is null || retorno.Canceled) return;

        var exclusao = await FuncionarioServico.ExcluirAsync(item.Id);
        if (exclusao.Sucesso)
        {
            Notificacoes.Sucesso(exclusao.Mensagem ?? "Registro excluído.");
            await Carregar();
        }
        else
            Notificacoes.Erro(exclusao.Mensagem ?? "Não foi possível excluir.");
    }
}

