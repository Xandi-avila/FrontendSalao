@page "/"
@layout AdminLayout

<CabecalhoPagina Titulo="Painel administrativo"
                 Subtitulo="Bem-vindo ao Salão Admin — gestão do salão de beleza" />

<MudGrid Spacing="3">
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6">Funcionários</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Equipe e permissões</MudText>
                </div>
                <MudButton Href="/funcionarios" Variant="Variant.Text" Color="Color.Primary" Class="ml-auto">Acessar</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.People" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6">Clientes</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Cadastro de clientes</MudText>
                </div>
                <MudButton Href="/clientes" Variant="Variant.Text" Color="Color.Primary" Class="ml-auto">Acessar</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.ContentCut" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6">Serviços</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Catálogo do salão</MudText>
                </div>
                <MudButton Href="/servicos" Variant="Variant.Text" Color="Color.Primary" Class="ml-auto">Acessar</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
</MudGrid>

<MudGrid Spacing="3" Class="mt-1">
    <MudItem xs="12" sm="6" md="6">
        <MudCard Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Info" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6">Agenda e agendamentos</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Disponibilidade e reservas</MudText>
                </div>
                <MudButton Href="/agenda" Variant="Variant.Text" Color="Color.Primary" Class="ml-auto">Acessar</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="6">
        <MudCard Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Success" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.PointOfSale" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6">Vendas (PDV)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Produtos e serviços</MudText>
                </div>
                <MudButton Href="/vendas" Variant="Variant.Text" Color="Color.Primary" Class="ml-auto">Acessar</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="12">
        <ResumoAgendamentosSemana />
    </MudItem>
</MudGrid>
