@inherits LayoutComponentBase

@inject IPreferenciaTemaServico PreferenciaTema



<MudThemeProvider Theme="_theme"

                  IsDarkMode="_modoEscuro"

                  IsDarkModeChanged="AoAlterarModoEscuroAsync" />

<MudPopoverProvider />

<MudDialogProvider />

<MudSnackbarProvider />



<MudLayout>

    <MudDrawer @bind-Open="_drawerOpen"

               Elevation="2"

               Variant="@DrawerVariant.Responsive"

               ClipMode="DrawerClipMode.Always">

        <MudDrawerHeader Class="pa-4">

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">

                <MudText Typo="Typo.subtitle1" Color="Color.Primary"><b>Painel</b></MudText>

                <MudTooltip Text="@(_modoEscuro ? "Usar modo claro" : "Usar modo escuro")">

                    <MudIconButton Icon="@(_modoEscuro ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"

                                   Color="Color.Primary"

                                   OnClick="AlternarTemaAsync"

                                   aria-label="@(_modoEscuro ? "Modo claro" : "Modo escuro")" />

                </MudTooltip>

            </MudStack>

        </MudDrawerHeader>

        <MudNavMenu>

            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">

                Início

            </MudNavLink>

            <MudText Typo="Typo.overline" Class="px-4 mt-4 mb-1">Cadastros</MudText>

            <MudNavLink Href="/funcionarios" Icon="@Icons.Material.Filled.Badge">Funcionários</MudNavLink>

            <MudNavLink Href="/clientes" Icon="@Icons.Material.Filled.People">Clientes</MudNavLink>

            <MudNavLink Href="/produtos" Icon="@Icons.Material.Filled.Inventory2">Produtos</MudNavLink>

            <MudNavLink Href="/categorias" Icon="@Icons.Material.Filled.Category">Categorias</MudNavLink>

            <MudNavLink Href="/servicos" Icon="@Icons.Material.Filled.ContentCut">Serviços</MudNavLink>

            <MudText Typo="Typo.overline" Class="px-4 mt-4 mb-1">Operação</MudText>
            <MudNavLink Href="/agenda" Icon="@Icons.Material.Filled.CalendarMonth">Agenda e agendamentos</MudNavLink>
            <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.Logout">Sair</MudNavLink>

        </MudNavMenu>

    </MudDrawer>



    <MudMainContent Class="pa-4 pa-md-6">

        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">

            @Body

        </MudContainer>

    </MudMainContent>

</MudLayout>



@code {

    private bool _drawerOpen = true;

    private bool _modoEscuro;

    private bool _preferenciaCarregada;



    private readonly MudTheme _theme = new()

    {

        PaletteLight = new PaletteLight

        {

            Primary = "#7B4B94",

            Secondary = "#E8B4CB",

            AppbarBackground = "#FFFFFF",

            Background = "#F5F3F7",

            Surface = "#FFFFFF"

        },

        PaletteDark = new PaletteDark

        {

            Primary = "#B88FD4",

            Secondary = "#E8B4CB",

            Tertiary = "#7B4B94",

            AppbarBackground = "#252030",

            Background = "#1A1620",

            Surface = "#252030",

            DrawerBackground = "#1E1A26",

            DrawerText = "rgba(255,255,255,0.87)",

            DrawerIcon = "rgba(255,255,255,0.54)",

            TextPrimary = "rgba(255,255,255,0.87)",

            TextSecondary = "rgba(255,255,255,0.60)",

            ActionDefault = "rgba(255,255,255,0.42)",

            Divider = "rgba(255,255,255,0.12)",

            TableLines = "rgba(255,255,255,0.12)",

            LinesDefault = "rgba(255,255,255,0.12)"

        },

        LayoutProperties = new LayoutProperties

        {

            DefaultBorderRadius = "8px"

        }

    };



    protected override async Task OnAfterRenderAsync(bool firstRender)

    {

        if (!firstRender || _preferenciaCarregada)

            return;



        _modoEscuro = await PreferenciaTema.ObterModoEscuroAsync();

        _preferenciaCarregada = true;

        StateHasChanged();

    }



    private async Task AlternarTemaAsync()

    {

        await AoAlterarModoEscuroAsync(!_modoEscuro);

    }



    private async Task AoAlterarModoEscuroAsync(bool modoEscuro)

    {

        if (_modoEscuro == modoEscuro && _preferenciaCarregada)

            return;



        _modoEscuro = modoEscuro;

        await PreferenciaTema.SalvarModoEscuroAsync(modoEscuro);

    }

}


