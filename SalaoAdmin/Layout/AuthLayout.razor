@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudSnackbarProvider />

<div class="auth-shell">
    <MudContainer MaxWidth="MaxWidth.Small" Class="auth-container">
        @Body
    </MudContainer>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7B4B94",
            Secondary = "#E8B4CB",
            Background = "#F5F3F7",
            Surface = "#FFFFFF"
        }
    };
}
