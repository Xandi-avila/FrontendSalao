@inherits LayoutComponentBase
@inject IPreferenciaTemaServico PreferenciaTema

<MudThemeProvider Theme="_theme" IsDarkMode="_modoEscuro" />
<MudSnackbarProvider />

<div class="auth-shell">
    @Body
</div>

@code {
    private bool _modoEscuro;
    private bool _preferenciaCarregada;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#398E97",
            Secondary = "#5FC7D0",
            Tertiary = "#96D7DB",
            Background = "#F2F5F5",
            Surface = "#FFFFFF",
            AppbarBackground = "#398E97",
            AppbarText = "#FFFFFF",
            TextPrimary = "#141C1E",
            TextSecondary = "#4A5557",
            Divider = "#D1E2E4",
            Success = "#1A8245",
            Warning = "#B27000",
            Error = "#D32F2F"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#4CD2EC",
            Secondary = "#3D9EB4",
            Background = "#0F1416",
            Surface = "#192224",
            TextPrimary = "#E1E8E9",
            TextSecondary = "#9AA7A9",
            Divider = "#334549",
            Success = "#4CE18B",
            Warning = "#FFC457",
            Error = "#FF8985"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _preferenciaCarregada)
            return;

        _modoEscuro = await PreferenciaTema.ObterModoEscuroAsync();
        _preferenciaCarregada = true;
        StateHasChanged();
    }
}
